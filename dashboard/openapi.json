    "schemas": {
      "Answer": {
        "description": "A human's resolution of an interaction.\n\nPermissions use ``decision`` (optionally with ``updated_input`` to run the\ntool with edited arguments); questions use ``text``. For a denied\npermission, ``text`` carries the reason shown to the agent.",
        "properties": {
          "decision": {
            "anyOf": [
              {
                "enum": [
                  "allow",
                  "deny"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Decision"
          },
          "text": {
            "default": "",
            "title": "Text",
            "type": "string"
          },
          "updated_input": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated Input"
          }
        },
        "title": "Answer",
        "type": "object"
      },
      "AnswerRequest": {
        "description": "A human's answer: ``decision`` for permissions, ``text`` for questions\n(or the deny reason).",
