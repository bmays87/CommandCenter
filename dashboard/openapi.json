    "/api/interactions/{interaction_id}/answer": {
      "post": {
        "description": "Resolve an interaction; the first answer wins (409 afterwards).",
        "operationId": "answer_interaction_api_interactions__interaction_id__answer_post",
        "parameters": [
          {
            "in": "path",
            "name": "interaction_id",
            "required": true,
            "schema": {
              "title": "Interaction Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
